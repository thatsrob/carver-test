		<script is:inline>
			(function () {
				var hdr = document.getElementById("carver-header");
				if (!hdr) return;
				var compactThreshold = 20;
				var yInit = window.scrollY || document.documentElement.scrollTop;
				var prevCompact = yInit > compactThreshold;
				var suppressCompactCube = yInit > compactThreshold;
				function syncHeaderScroll() {
					var y = window.scrollY || document.documentElement.scrollTop;
					var isMobile = window.innerWidth <= 767;
					var compact = isMobile ? true : y > compactThreshold;
					hdr.classList.toggle("is-compact", compact);
					if (suppressCompactCube) {
						suppressCompactCube = false;
						hdr.classList.remove("carver-header--suppress-compact-cube");
					}
					if (prevCompact && !compact) {
						hdr.classList.add("carver-header--play-expand-cube");
						window.clearTimeout(hdr._expandCubeT);
						hdr._expandCubeT = window.setTimeout(function () {
							hdr.classList.remove("carver-header--play-expand-cube");
						}, 900);
					}
					prevCompact = compact;
				}
				if (suppressCompactCube) hdr.classList.add("carver-header--suppress-compact-cube");
				syncHeaderScroll();
				window.addEventListener("scroll", syncHeaderScroll, { passive: true });
				window.addEventListener("resize", syncHeaderScroll, { passive: true });
			})();
		</script>
		<script is:inline>
			(function () {
				var hdr = document.getElementById("carver-header");
				var nav = document.getElementById("carver-nav");
				var toggle = document.getElementById("carver-nav-toggle");
				if (!hdr || !nav || !toggle) return;

				var mq = window.matchMedia("(max-width: 767px)");

				function setNavOpen(open) {
					hdr.classList.toggle("is-nav-open", open);
					toggle.setAttribute("aria-expanded", open ? "true" : "false");
					toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
					document.body.style.overflow = open ? "hidden" : "";
				}

				function closeNav() {
					setNavOpen(false);
					nav.querySelectorAll("li.is-submenu-open").forEach(function (li) {
						li.classList.remove("is-submenu-open");
					});
				}

				toggle.addEventListener("click", function () {
					if (!mq.matches) return;
					setNavOpen(!hdr.classList.contains("is-nav-open"));
				});

				var submenuParents = nav.querySelectorAll(".carver-nav__item--has-sub > a");
				submenuParents.forEach(function (a) {
					a.addEventListener("click", function (e) {
						if (!mq.matches) return;
						e.preventDefault();
						var li = a.parentElement;
						if (li) li.classList.toggle("is-submenu-open");
					});
				});

				nav.querySelectorAll("a").forEach(function (a) {
					a.addEventListener("click", function () {
						if (!mq.matches) return;
						if (a.matches(".carver-nav__item--has-sub > a")) return;
						closeNav();
					});
				});

				document.addEventListener("keydown", function (e) {
					if (e.key === "Escape" && hdr.classList.contains("is-nav-open")) closeNav();
				});

				mq.addEventListener("change", function () {
					if (!mq.matches) {
						closeNav();
					}
				});

				window.addEventListener(
					"resize",
					function () {
						if (window.innerWidth > 767) closeNav();
					},
					{ passive: true }
				);
			})();
		</script>
	</body>
</html>
