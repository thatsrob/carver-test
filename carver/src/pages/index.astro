---
import "../styles/carver-home.css";
import CarverMain from "../components/carver/CarverMain.astro";
import { loadCarverHomepage } from "../lib/carver-home-load";

const { data, cacheHints } = await loadCarverHomepage();
for (const h of cacheHints) {
	if (h) Astro.cache.set(h);
}

const L = data.layout;
const U = L.uploadsBase;
const H = L.header;
const F = L.footer;
const fav = L.favicons;
const META = data.meta;

function absoluteOgImage(): string {
	const og = META.ogImage;
	if (!og) return `https://gocarverllc.com${U}/2021/02/Carver-law-hero-background.jpg`;
	if (og.startsWith("http")) return og;
	return `${META.siteOrigin ?? "https://gocarverllc.com"}${og}`;
}

/** srcset in JSON lists paths relative to uploadsBase (comma-separated "path 300w" pairs). */
function uploadsSrcset(spec: string) {
	return spec
		.split(", ")
		.map((part) => {
			const bits = part.trim().split(/\s+/);
			const rel = bits[0];
			const rest = bits.slice(1).join(" ");
			return `${U}/${rel}${rest ? ` ${rest}` : ""}`;
		})
		.join(", ");
}
---

<!doctype html>
<html lang={L.htmlLang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={META.description} />
		<title>{META.title}</title>
		<link rel="icon" type="image/png" sizes="32x32" href={`${U}/${fav["32"]}`} />
		<link rel="icon" type="image/png" sizes="192x192" href={`${U}/${fav["192"]}`} />
		<link rel="apple-touch-icon" href={`${U}/${fav.apple}`} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@300;400;600&family=Ubuntu:wght@300;400;500;600;700&family=Nunito:wght@400;600&display=swap"
			rel="stylesheet"
		/>
		<link
			href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css"
			rel="stylesheet"
			crossorigin="anonymous"
			referrerpolicy="no-referrer"
		/>
		<meta property="og:image" content={absoluteOgImage()} />
	</head>
	<body class="carver-home">
		<header class="carver-header" id="carver-header">
				<div class="carver-header__inner">
					<div class="carver-header__left">
						<a class="carver-logo" href="/" aria-label={H.logoAriaLabel}>
							<img
								src={`${U}/${H.logo.src}`}
								width={H.logo.width}
								height={H.logo.height}
								alt={H.logo.alt}
							/>
						</a>
						<button
							type="button"
							class="carver-nav__toggle"
							id="carver-nav-toggle"
							aria-expanded="false"
							aria-controls="carver-nav"
							aria-label={H.navToggle.openLabel}
							data-nav-open-label={H.navToggle.openLabel}
							data-nav-close-label={H.navToggle.closeLabel}
						>
							<i class="fa fa-bars carver-nav__toggle-icon carver-nav__toggle-icon--open" aria-hidden="true"></i>
							<i class="fa fa-times carver-nav__toggle-icon carver-nav__toggle-icon--close" aria-hidden="true"></i>
						</button>
						<nav class="carver-nav" id="carver-nav" aria-label={H.navAriaLabel}>
							<ul>
								{H.navItems.map((item) =>
									item.children?.length ? (
										<li class="carver-nav__item--has-sub">
											<a href={item.href}>
												{item.label}
												<i class="fa fa-chevron-down carver-nav__caret" aria-hidden="true"></i>
											</a>
											<ul class="sub-menu">
												{item.children.map((sub) => (
													<li>
														<a href={sub.href}>{sub.label}</a>
													</li>
												))}
											</ul>
										</li>
									) : (
										<li>
											<a href={item.href} aria-current={item.href === "/" ? "page" : undefined}>
												{item.label}
											</a>
										</li>
									),
								)}
							</ul>
						</nav>
					</div>
					<div class="carver-header__end">
						<div class="carver-header__tel">
							<a href={`tel:${H.phone.tel}`}>{H.phone.display}</a>
						</div>
						<div class="carver-header__cta">
							<a class="carver-btn--header" href={H.cta.href}>{H.cta.label}</a>
						</div>
					</div>
				</div>
		</header>

		<div class="carver-wrap">
			<main id="main">
				<CarverMain data={data} />
			</main>

			<footer class="carver-footer">
				<div class="carver-footer__grid">
					<div class="carver-footer__brand">
						<img
							src={`${U}/${F.logo.src}`}
							width={F.logo.width}
							height={F.logo.height}
							alt={F.logo.alt}
						/>
						<a
							class="carver-footer__linkedin"
							href={F.linkedin.href}
							target="_blank"
							rel="noopener noreferrer"
							aria-label={F.linkedin.ariaLabel}
						>
							<img
								src={F.linkedin.iconSrc}
								width={F.linkedin.iconWidth}
								height={F.linkedin.iconHeight}
								alt=""
							/>
						</a>
					</div>
					<div>
						<ul class="footer-links">
							{F.links.map((link) => (
								<li>
									<a href={link.href}>{link.label}</a>
								</li>
							))}
						</ul>
					</div>
					<div class="carver-footer__contact">
						<h4>
							<a href={F.contact.headingHref}>{F.contact.heading}</a>
						</h4>
						<p>
							{F.contact.phonePrefix}{" "}
							<a href={`tel:${F.contact.phoneTel}`}>{F.contact.phoneDisplay}</a>
							<br />
							{F.contact.faxLine}
						</p>
						<p set:html={F.contact.addressHtml} />
					</div>
					<div>
						<iframe
							title={F.map.title}
							src={F.map.src}
							width="100%"
							height="200"
							style="border:0"
							allowfullscreen=""
							loading="lazy"
							referrerpolicy="no-referrer-when-downgrade"></iframe>
					</div>
				</div>
				<div class="fineprint">
					<div class="fineprint__copy">
						<p>{F.fineprint.copyright}</p>
						<p>{F.fineprint.disclaimer}</p>
					</div>
					<div class="fineprint__mark">
						<a href={F.mark.href} target="_blank" rel="noopener noreferrer">
							<img
								src={`${U}/${F.mark.img.src}`}
								srcset={uploadsSrcset(F.mark.img.srcset)}
								sizes={F.mark.img.sizes}
								width={F.mark.img.width}
								height={F.mark.img.height}
								alt={F.mark.img.alt}
								loading="lazy"
							/>
						</a>
					</div>
				</div>
			</footer>
		</div>

		<a class="admin-link-fixed" href={L.adminLink.href}>{L.adminLink.label}</a>

		<style is:global>
			.visually-hidden {
				position: absolute;
				width: 1px;
				height: 1px;
				padding: 0;
				margin: -1px;
				overflow: hidden;
				clip: rect(0, 0, 0, 0);
				white-space: nowrap;
				border: 0;
			}
		</style>

		<script is:inline>
			(function () {
				var hdr = document.getElementById("carver-header");
				if (!hdr) return;
				var compactThreshold = 20;
				var yInit = window.scrollY || document.documentElement.scrollTop;
				var prevCompact = yInit > compactThreshold;
				var suppressCompactCube = yInit > compactThreshold;
				function syncHeaderScroll() {
					var y = window.scrollY || document.documentElement.scrollTop;
					var isMobile = window.innerWidth <= 767;
					var compact = isMobile ? true : y > compactThreshold;
					hdr.classList.toggle("is-compact", compact);
					if (suppressCompactCube) {
						suppressCompactCube = false;
						hdr.classList.remove("carver-header--suppress-compact-cube");
					}
					if (prevCompact && !compact) {
						hdr.classList.add("carver-header--play-expand-cube");
						window.clearTimeout(hdr._expandCubeT);
						hdr._expandCubeT = window.setTimeout(function () {
							hdr.classList.remove("carver-header--play-expand-cube");
						}, 900);
					}
					prevCompact = compact;
				}
				if (suppressCompactCube) hdr.classList.add("carver-header--suppress-compact-cube");
				syncHeaderScroll();
				window.addEventListener("scroll", syncHeaderScroll, { passive: true });
				window.addEventListener("resize", syncHeaderScroll, { passive: true });
			})();
		</script>
		<script is:inline>
			(function () {
				var hdr = document.getElementById("carver-header");
				var nav = document.getElementById("carver-nav");
				var toggle = document.getElementById("carver-nav-toggle");
				if (!hdr || !nav || !toggle) return;

				var openLabel = toggle.getAttribute("data-nav-open-label") || "Open menu";
				var closeLabel = toggle.getAttribute("data-nav-close-label") || "Close menu";

				var mq = window.matchMedia("(max-width: 767px)");

				function updateMobileNavOffset() {
					if (!mq.matches) {
						hdr.style.removeProperty("--carver-mobile-nav-offset");
						return;
					}
					hdr.style.setProperty("--carver-mobile-nav-offset", hdr.offsetHeight + "px");
				}

				function setNavOpen(open) {
					if (open) updateMobileNavOffset();
					hdr.classList.toggle("is-nav-open", open);
					toggle.setAttribute("aria-expanded", open ? "true" : "false");
					toggle.setAttribute("aria-label", open ? closeLabel : openLabel);
					document.body.style.overflow = open ? "hidden" : "";
					if (!open) {
						nav.querySelectorAll("li.is-submenu-open").forEach(function (li) {
							li.classList.remove("is-submenu-open");
						});
					} else if (mq.matches) {
						var pa = nav.querySelector(".carver-nav__item--has-sub");
						if (pa) pa.classList.add("is-submenu-open");
					}
				}

				function closeNav() {
					setNavOpen(false);
				}

				toggle.addEventListener("click", function () {
					if (!mq.matches) return;
					setNavOpen(!hdr.classList.contains("is-nav-open"));
				});

				var submenuParents = nav.querySelectorAll(".carver-nav__item--has-sub > a");
				submenuParents.forEach(function (a) {
					a.addEventListener("click", function (e) {
						if (!mq.matches) return;
						e.preventDefault();
						var li = a.parentElement;
						if (li) li.classList.toggle("is-submenu-open");
					});
				});

				nav.querySelectorAll("a").forEach(function (a) {
					a.addEventListener("click", function () {
						if (!mq.matches) return;
						if (a.matches(".carver-nav__item--has-sub > a")) return;
						closeNav();
					});
				});

				document.addEventListener("keydown", function (e) {
					if (e.key === "Escape" && hdr.classList.contains("is-nav-open")) closeNav();
				});

				mq.addEventListener("change", function () {
					if (!mq.matches) {
						closeNav();
					}
					updateMobileNavOffset();
				});

				updateMobileNavOffset();
				window.addEventListener("resize", updateMobileNavOffset, { passive: true });
				if (typeof ResizeObserver !== "undefined") {
					new ResizeObserver(updateMobileNavOffset).observe(hdr);
				}

				window.addEventListener(
					"resize",
					function () {
						if (window.innerWidth > 767) closeNav();
					},
					{ passive: true }
				);
			})();
		</script>
	</body>
</html>
