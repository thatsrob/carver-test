---
import "../styles/carver-home.css";
import CarverMain from "../components/carver/CarverMain.astro";
import { loadCarverHomepage } from "../lib/carver-home-load";

const { data, cacheHints } = await loadCarverHomepage();
for (const h of cacheHints) {
	if (h) Astro.cache.set(h);
}

const U = "/carver/wp-content/uploads";
const META = data.meta;
---

<!doctype html>
<html lang="en-US">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={META.description} />
		<title>{META.title}</title>
		<link rel="icon" type="image/png" sizes="32x32" href={`${U}/2021/03/cropped-Carver-associates-favicon-32x32.png`} />
		<link rel="icon" type="image/png" sizes="192x192" href={`${U}/2021/03/cropped-Carver-associates-favicon-192x192.png`} />
		<link rel="apple-touch-icon" href={`${U}/2021/03/cropped-Carver-associates-favicon-180x180.png`} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@300;400;600&family=Ubuntu:wght@300;400;500;600;700&family=Nunito:wght@400;600&display=swap"
			rel="stylesheet"
		/>
		<link
			href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css"
			rel="stylesheet"
			crossorigin="anonymous"
			referrerpolicy="no-referrer"
		/>
		<meta property="og:image" content={`https://gocarverllc.com${U}/2021/02/Carver-law-hero-background.jpg`} />
	</head>
	<body class="carver-home">
		<header class="carver-header" id="carver-header">
				<div class="carver-header__inner">
					<div class="carver-header__left">
						<a class="carver-logo" href="/" aria-label="Carver & Associates home">
							<img src={`${U}/2021/02/Carver-associates-logo.png`} width="210" height="57" alt="Carver associates logo" />
						</a>
						<button
							type="button"
							class="carver-nav__toggle"
							id="carver-nav-toggle"
							aria-expanded="false"
							aria-controls="carver-nav"
							aria-label="Open menu"
						>
							<i class="fa fa-bars carver-nav__toggle-icon carver-nav__toggle-icon--open" aria-hidden="true"></i>
							<i class="fa fa-times carver-nav__toggle-icon carver-nav__toggle-icon--close" aria-hidden="true"></i>
						</button>
						<nav class="carver-nav" id="carver-nav" aria-label="Main">
							<ul>
								<li><a href="/" aria-current="page">Home</a></li>
								<li><a href="https://gocarverllc.com/thomas-carver/">About</a></li>
								<li class="carver-nav__item--has-sub">
									<a href="https://gocarverllc.com/criminal-lawyer-springfield-mo/">
										Practice Areas
										<i class="fa fa-chevron-down carver-nav__caret" aria-hidden="true"></i>
									</a>
									<ul class="sub-menu">
										<li><a href="https://gocarverllc.com/federal-criminal-lawyer/">Federal Criminal</a></li>
										<li><a href="https://gocarverllc.com/sex-crime-lawyer/">Sex Crimes</a></li>
										<li><a href="https://gocarverllc.com/child-pornography-lawyer/">Child Pornography</a></li>
										<li><a href="https://gocarverllc.com/white-collar-crime-lawyer/">White Collar Crime</a></li>
										<li><a href="https://gocarverllc.com/fraud-lawyers/">Fraud</a></li>
										<li><a href="https://gocarverllc.com/drug-conspiracy/">Drug Conspiracy</a></li>
										<li><a href="https://gocarverllc.com/dwi-lawyer-springfield-mo/">DWI</a></li>
										<li><a href="https://gocarverllc.com/springfield-traffic-tickets/">Traffic Tickets</a></li>
									</ul>
								</li>
								<li><a href="https://gocarverllc.com/blog/">Blog</a></li>
								<li><a href="https://gocarverllc.com/contact/">Contact</a></li>
							</ul>
						</nav>
					</div>
					<div class="carver-header__end">
						<div class="carver-header__tel">
							<a href="tel:4173501172">(417) 350-1172</a>
						</div>
						<div class="carver-header__cta">
							<a class="carver-btn--header" href="https://gocarverllc.com/contact/">Free consultation</a>
						</div>
					</div>
				</div>
		</header>

		<div class="carver-wrap">
			<main id="main">
				<CarverMain data={data} />
			</main>

			<footer class="carver-footer">
				<div class="carver-footer__grid">
					<div class="carver-footer__brand">
						<img src={`${U}/2021/02/Carver-associates-logo.png`} width="240" height="65" alt="Carver associates logo" />
						<a
							class="carver-footer__linkedin"
							href="https://www.linkedin.com/in/thomas-carver-a6a44ab/"
							target="_blank"
							rel="noopener noreferrer"
							aria-label="Thomas Carver on LinkedIn"
						>
							<img src="/carver/icons/linkedin.svg" width="32" height="32" alt="" />
						</a>
					</div>
					<div>
						<ul class="footer-links">
							<li><a href="/">Home</a></li>
							<li><a href="https://gocarverllc.com/criminal-lawyer-springfield-mo/">Practice Areas</a></li>
							<li><a href="https://gocarverllc.com/thomas-carver/">About Us</a></li>
							<li><a href="https://gocarverllc.com/blog/">Blog</a></li>
							<li><a href="https://gocarverllc.com/contact/">Contact</a></li>
							<li><a href="https://gocarverllc.com/privacy-policy/">Privacy Policy</a></li>
						</ul>
					</div>
					<div class="carver-footer__contact">
						<h4><a href="https://gocarverllc.com/contact/">CONTACT US</a></h4>
						<p>
							Phone: <a href="tel:4173501172">(417) 350-1172</a><br />
							Fax: (417) 350-1182
						</p>
						<p><strong>2974 E Battlefield Rd, Springfield, MO 65804</strong></p>
					</div>
					<div>
						<iframe
							title="Carver & Associates on Google Maps"
							src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d50876.44058656002!2d-93.2768278655253!3d37.157988913798484!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x87cf63a959048a2f%3A0xeb431c8f474eb409!2sCarver%20%26%20Associates!5e0!3m2!1sen!2sus!4v1765987874693!5m2!1sen!2sus"
							width="100%"
							height="200"
							style="border:0"
							allowfullscreen=""
							loading="lazy"
							referrerpolicy="no-referrer-when-downgrade"></iframe>
					</div>
				</div>
				<div class="fineprint">
					<div class="fineprint__copy">
						<p>Copyright © 2021–2026 Carver & Associates</p>
						<p>
							Use of the website does not constitute legal advice or form an attorney/client relationship.
						</p>
					</div>
					<div class="fineprint__mark">
						<a href="https://goconstellation.com" target="_blank" rel="noopener noreferrer">
							<img
								src={`${U}/2021/07/Constellation-Marketing-Lawyer-Marketing.png`}
								srcset={`${U}/2021/07/Constellation-Marketing-Lawyer-Marketing.png 350w, ${U}/2021/07/Constellation-Marketing-Lawyer-Marketing-300x67.png 300w`}
								sizes="210px"
								width="210"
								height="47"
								alt="Constellation Marketing Lawyer Marketing"
								loading="lazy"
							/>
						</a>
					</div>
				</div>
			</footer>
		</div>

		<a class="admin-link-fixed" href="/_emdash/admin">EmDash admin</a>

		<style is:global>
			.visually-hidden {
				position: absolute;
				width: 1px;
				height: 1px;
				padding: 0;
				margin: -1px;
				overflow: hidden;
				clip: rect(0, 0, 0, 0);
				white-space: nowrap;
				border: 0;
			}
		</style>

		<script is:inline>
			(function () {
				var hdr = document.getElementById("carver-header");
				if (!hdr) return;
				var compactThreshold = 20;
				var yInit = window.scrollY || document.documentElement.scrollTop;
				var prevCompact = yInit > compactThreshold;
				var suppressCompactCube = yInit > compactThreshold;
				function syncHeaderScroll() {
					var y = window.scrollY || document.documentElement.scrollTop;
					var isMobile = window.innerWidth <= 767;
					var compact = isMobile ? true : y > compactThreshold;
					hdr.classList.toggle("is-compact", compact);
					if (suppressCompactCube) {
						suppressCompactCube = false;
						hdr.classList.remove("carver-header--suppress-compact-cube");
					}
					if (prevCompact && !compact) {
						hdr.classList.add("carver-header--play-expand-cube");
						window.clearTimeout(hdr._expandCubeT);
						hdr._expandCubeT = window.setTimeout(function () {
							hdr.classList.remove("carver-header--play-expand-cube");
						}, 900);
					}
					prevCompact = compact;
				}
				if (suppressCompactCube) hdr.classList.add("carver-header--suppress-compact-cube");
				syncHeaderScroll();
				window.addEventListener("scroll", syncHeaderScroll, { passive: true });
				window.addEventListener("resize", syncHeaderScroll, { passive: true });
			})();
		</script>
		<script is:inline>
			(function () {
				var hdr = document.getElementById("carver-header");
				var nav = document.getElementById("carver-nav");
				var toggle = document.getElementById("carver-nav-toggle");
				if (!hdr || !nav || !toggle) return;

				var mq = window.matchMedia("(max-width: 767px)");

				function updateMobileNavOffset() {
					if (!mq.matches) {
						hdr.style.removeProperty("--carver-mobile-nav-offset");
						return;
					}
					hdr.style.setProperty("--carver-mobile-nav-offset", hdr.offsetHeight + "px");
				}

				function setNavOpen(open) {
					if (open) updateMobileNavOffset();
					hdr.classList.toggle("is-nav-open", open);
					toggle.setAttribute("aria-expanded", open ? "true" : "false");
					toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
					document.body.style.overflow = open ? "hidden" : "";
					if (!open) {
						nav.querySelectorAll("li.is-submenu-open").forEach(function (li) {
							li.classList.remove("is-submenu-open");
						});
					} else if (mq.matches) {
						var pa = nav.querySelector(".carver-nav__item--has-sub");
						if (pa) pa.classList.add("is-submenu-open");
					}
				}

				function closeNav() {
					setNavOpen(false);
				}

				toggle.addEventListener("click", function () {
					if (!mq.matches) return;
					setNavOpen(!hdr.classList.contains("is-nav-open"));
				});

				var submenuParents = nav.querySelectorAll(".carver-nav__item--has-sub > a");
				submenuParents.forEach(function (a) {
					a.addEventListener("click", function (e) {
						if (!mq.matches) return;
						e.preventDefault();
						var li = a.parentElement;
						if (li) li.classList.toggle("is-submenu-open");
					});
				});

				nav.querySelectorAll("a").forEach(function (a) {
					a.addEventListener("click", function () {
						if (!mq.matches) return;
						if (a.matches(".carver-nav__item--has-sub > a")) return;
						closeNav();
					});
				});

				document.addEventListener("keydown", function (e) {
					if (e.key === "Escape" && hdr.classList.contains("is-nav-open")) closeNav();
				});

				mq.addEventListener("change", function () {
					if (!mq.matches) {
						closeNav();
					}
					updateMobileNavOffset();
				});

				updateMobileNavOffset();
				window.addEventListener("resize", updateMobileNavOffset, { passive: true });
				if (typeof ResizeObserver !== "undefined") {
					new ResizeObserver(updateMobileNavOffset).observe(hdr);
				}

				window.addEventListener(
					"resize",
					function () {
						if (window.innerWidth > 767) closeNav();
					},
					{ passive: true }
				);
			})();
		</script>
	</body>
</html>
